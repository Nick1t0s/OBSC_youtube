api:
  base_url: http://localhost:8000
  poll_interval_sec: 2
  request_timeout_sec: 60
  upload_timeout_sec: 1800
  # Сколько задач держим одновременно в статусе processing на OBSC.
  # Перед отправкой нового видео ждём, пока число processing-записей < max_in_flight.
  max_in_flight: 4

storage:
  db_path: ./data/scraper.db
  download_dir: ./data/downloads

youtube:
  source_service: youtube
  # Режим по умолчанию для каналов, где не указан явно. video | audio
  default_mode: video
  # Путь к cookies.txt в Netscape-формате (экспорт из браузера).
  # Нужен, чтобы обходить YouTube anti-bot ("Sign in to confirm you're not a bot").
  # Оставь пустым/закомментируй, если не используешь.
  cookiefile: ./cookies.txt
  # 720p, иначе максимальное разрешение < 720p. Звук и видео мержатся в mp4.
  video_format: "bv*[height=720]+ba/b[height=720]/bv*[height<720]+ba/b[height<720]"
  # Для audio-режима — берём лучшее аудио, перекодируем в audio_codec через ffmpeg.
  # Это нужно, чтобы OBSC получил файл с явно аудийным расширением (mp3/m4a),
  # иначе он пытается извлекать кадры из .webm → ffmpeg exit 234.
  audio_format: "bestaudio/best"
  audio_codec: mp3
  audio_quality: "192"
  merge_output_format: mp4
  # Сколько раз повторять скачивание после ошибки yt-dlp. 0 = без повторов.
  # После исчерпания попыток видео уходит в download_error и при следующем
  # прогоне будет пропущено (input-level dedup по db.exists).
  download_retries: 3
  # Пауза между попытками скачивания (секунды).
  download_retry_delay_sec: 5

channels_file: ./channels.json

# Расписание периодического сканирования.
# scan_interval_sec  — как часто запускать новый прогон по каналам.
# check_interval_sec — как часто читать last_start_file и решать, пора ли сканировать.
# last_start_file    — путь к файлу с datetime начала последнего прогона (ISO-формат).
#                      Если файла нет или он пуст — сканируем сразу. Удалить файл
#                      вручную = триггер немедленного сканирования.
schedule:
  scan_interval_sec: 3600
  check_interval_sec: 60
  last_start_file: ./data/last_start.txt

logging:
  level: INFO
  file: ./data/scraper.log

# Веб-панель администратора.
# Если enabled: false — сервер не поднимается.
# secret_key — случайный ключ сессий; если пустой, генерируется при каждом запуске
# (все сессии сбрасываются при рестарте). Задайте фиксированное значение для
# персистентных сессий.
admin:
  enabled: true
  host: "0.0.0.0"
  port: 8080
  username: admin
  password: Ваш пароль
  secret_key: ""
